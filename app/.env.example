# Supabase — Settings > API del proyecto
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com/api-keys (re_xxxxxxxxx)
# Opcional: sin esta variable las invitaciones se crean igual y el link se copia desde el panel.
RESEND_API_KEY=
# Remitente. Para producción verificá tu dominio en Resend y usá algo como onboarding@grupoklu.com
EMAIL_FROM=onboarding@resend.dev

# Secreto para firmar cookies de sesión (openssl rand -hex 32)
APP_SECRET=
# Contraseña del panel admin
ADMIN_PASSWORD=
# URL pública de la app (en Vercel: https://tu-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
